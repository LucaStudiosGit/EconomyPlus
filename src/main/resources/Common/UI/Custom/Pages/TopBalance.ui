  $C = "../Common.ui";

  @CustomStyle = TextButtonStyle(
    Default: (LabelStyle: (FontSize: 18, TextColor: #c4b67a, RenderBold: true, Alignment: Center), Background: #1a1a1a(0.7)),
    Hovered: (LabelStyle: (FontSize: 18, TextColor: #ffe6a0, RenderBold: true, Alignment: Center), Background: #2a2a2a(0.85)),
    Pressed: (LabelStyle: (FontSize: 18, TextColor: #7a6f3d, RenderBold: true, Alignment: Center), Background: #0f0f0f(0.9)),
    Disabled: (LabelStyle: (FontSize: 18, TextColor: #555555, RenderBold: true, Alignment: Center), Background: #1a1a1a(0.5)),
    Sounds: $C.@ButtonSounds,
  );

  @CustomStyleDisabled = TextButtonStyle(
    Default: (LabelStyle: (FontSize: 18, TextColor: #555555, RenderBold: true, Alignment: Center), Background: #1a1a1a(0.5)),
  );

  $C.@PageOverlay {

      $C.@DecoratedContainer {
      Anchor: (Width: 1050, Height: 625);

      #Title {
        Group {
          $C.@Title {
            @Text = "Top Balance  ";
          }
        }
      }

      Group #PlayersList {
          Anchor: (Width: 900, Top: 60);
          Label #PlayerRowTemplate {
              Text: "PlayerName";
              Anchor: (Height: 35);
              Style: (FontSize: 22, TextColor: #aaaaaa, Alignment: Center);
          }
      }

      Label #GapBottom {
          Text: "";
          Anchor: (Height: 12);
      }
        TextButton #PrevPageButton {
          Anchor: (Left: 40, Bottom: 15, Width: 140, Height: 44);
          Text: "< Previous";
          Style: @CustomStyle;
        }
        TextButton #NextPageButton {
          Anchor: (Right: 40, Bottom: 15, Width: 140, Height: 44);
          Text: "Next >";
          Style: @CustomStyle;
        }
        Label #PageNumber {
          Text: "1/10";
          Anchor: (Bottom: 25, Height: 15);
          Style: (FontSize: 20, TextColor: #aaaaaa, Alignment: Center);
        }
      }
  }
